TZ=America/Paramaribo

##############################################
#              BACKUP SERVICE
##############################################
# Backup destination inside container (maps to /home/Data/backups on host)
BACKUP_DIR=/backups

# Homelab repo path inside container
HOMELAB_DIR=/homelab

##############################################
#              SCHEDULE
##############################################
# Daily backup time (24h format, HH:MM)
DAILY_BACKUP_TIME=03:00

# Day of week for weekly full backup (0=Sunday)
WEEKLY_BACKUP_DAY=0

##############################################
#           RETENTION POLICY
##############################################
# Number of daily backups to keep
RETENTION_DAILY=7

# Number of weekly backups to keep
RETENTION_WEEKLY=4

##############################################
#         POSTGRES CONTAINERS
##############################################
# Shared PostgreSQL container name and user
PG_CONTAINER=postgres
PG_USER=postgres
PG_DATABASES=postgres,n8n

# Immich PostgreSQL container name and user
IMMICH_PG_CONTAINER=immich_postgres
IMMICH_PG_USER=postgres
IMMICH_PG_DATABASES=immich

##############################################
#         DOCKER VOLUMES TO BACKUP
##############################################
# Comma-separated list of named Docker volumes
BACKUP_VOLUMES=homelab_postgres-data,homelab_pgadmin-data,homelab_n8n_data

##############################################
#         SERVICES TO BACKUP
##############################################
# Comma-separated list of service directories to backup configs from
BACKUP_SERVICES=cloudflared,dash,homarr,home-assistant,immich,jellyfin,jellyseerr,n8n,nextcloud,nginx-manager,pihole,prowlarr,qbittorrents,radarr,readarr,sonarr,suwayomi

##############################################
#         LARGE DATA BACKUP
##############################################
# Set to "true" to include Immich library in weekly backups
# WARNING: This can be very large
BACKUP_IMMICH_LIBRARY=false

##############################################
#       CLOUD BACKUP (Google Drive)
##############################################
# Enable sync to cloud after local backup
CLOUD_BACKUP_ENABLED=false

# rclone remote name (configured in rclone/rclone.conf)
RCLONE_REMOTE=gdrive

# Destination folder in Google Drive
RCLONE_DEST_PATH=homelab-backups

# Cloud retention in days
CLOUD_RETENTION_DAYS=7

# Bandwidth limit (optional, e.g. 5M)
# RCLONE_BWLIMIT=

##############################################
#            NOTIFICATIONS
##############################################
# ntfy.sh URL (use https://ntfy.sh for cloud, or your self-hosted URL)
NTFY_URL=https://ntfy.sh

# ntfy.sh topic (use a unique, hard-to-guess string)
NTFY_TOPIC=homelab-backup-alerts-CHANGE-ME
