TZ=America/Paramaribo

##############################################
#             DISK MONITOR
##############################################
# Check interval in seconds (21600 = 6 hours)
CHECK_INTERVAL=21600

# NVMe device path
NVME_DEVICE=/dev/nvme0n1

# HDD device path (leave empty to skip)
HDD_DEVICE=/dev/sda

##############################################
#          TEMPERATURE THRESHOLDS
##############################################
# NVMe temperature warning (Celsius)
NVME_TEMP_WARN=70

# HDD temperature warning (Celsius)
HDD_TEMP_WARN=50

##############################################
#       DISK SPACE THRESHOLDS
##############################################
# Disk space usage warning percentage
DISK_USAGE_WARN=85
DISK_USAGE_CRITICAL=95

##############################################
#            NOTIFICATIONS
##############################################
# ntfy.sh URL (use https://ntfy.sh for cloud, or your self-hosted URL)
NTFY_URL=https://ntfy.sh

# ntfy.sh topic (use a unique, hard-to-guess string)
NTFY_TOPIC=homelab-disk-alerts-CHANGE-ME
