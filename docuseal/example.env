TZ=America/Paramaribo

##############################################
#                 DOCUSEAL
##############################################

# Public hostname exposed through Nginx Proxy Manager or Cloudflare Tunnel.
# Use the hostname only, without https://.
FORCE_SSL=docuseal.yourdomain.com

DATABASE_URL=postgresql://docuseal:change-me-postgres-password@docuseal-postgres:5432/docuseal

##############################################
#                DATABASE
##############################################

POSTGRES_USER=docuseal
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=docuseal
