TZ=America/Paramaribo

##############################################
#              INVOICE NINJA
##############################################

# Generate with: echo "base64:$(openssl rand -base64 32)"
APP_KEY=base64:your-generated-key-here

APP_URL=https://invoiceninja.yourdomain.com
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=America/Paramaribo

REQUIRE_HTTPS=false
TRUSTED_PROXIES=*

PDF_GENERATOR=snappdf
PHANTOMJS_PDF_GENERATION=false

QUEUE_CONNECTION=database

# Initial admin account (used on first run only)
IN_USER_EMAIL=admin@yourdomain.com
IN_PASSWORD=your-secure-password

##############################################
#                DATABASE
##############################################
DB_HOST=invoice-ninja-db
DB_PORT=3306
DB_DATABASE=ninja
DB_USERNAME=ninja
DB_PASSWORD=your-db-password

MYSQL_ROOT_PASSWORD=your-db-root-password
MYSQL_DATABASE=ninja
MYSQL_USER=ninja
MYSQL_PASSWORD=your-db-password

##############################################
#                   MAIL
##############################################
MAIL_MAILER=smtp
MAIL_HOST=smtp.yourdomain.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=invoices@yourdomain.com
MAIL_FROM_NAME=Invoice Ninja
