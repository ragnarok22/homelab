TZ=America/Paramaribo

##############################################
#                  NTFY
##############################################
# Public URL used in links and proxy-aware behavior.
NTFY_BASE_URL=https://ntfy.example.com
NTFY_BEHIND_PROXY=true

# Persist message cache and attachments across restarts.
NTFY_CACHE_FILE=/var/cache/ntfy/cache.db
NTFY_ATTACHMENT_CACHE_DIR=/var/cache/ntfy/attachments

# Optional: make the instance private before exposing it publicly.
# Generate users/tokens from inside the container or provision them here.
# NTFY_AUTH_FILE=/var/cache/ntfy/auth.db
# NTFY_AUTH_DEFAULT_ACCESS=deny-all
# NTFY_ENABLE_LOGIN=true
