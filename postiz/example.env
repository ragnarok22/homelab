TZ=America/Paramaribo

##############################################
#                  POSTIZ
##############################################

# Public URL exposed through Nginx Proxy Manager or Cloudflare Tunnel.
MAIN_URL=https://postiz.yourdomain.com
FRONTEND_URL=https://postiz.yourdomain.com
NEXT_PUBLIC_BACKEND_URL=https://postiz.yourdomain.com/api

# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-generate-a-unique-random-secret

DATABASE_URL=postgresql://postiz-user:change-me-postgres-password@postiz-postgres:5432/postiz-db-local
REDIS_URL=redis://postiz-redis:6379
BACKEND_INTERNAL_URL=http://localhost:3000
TEMPORAL_ADDRESS=postiz-temporal:7233
IS_GENERAL=true
DISABLE_REGISTRATION=false
RUN_CRON=true

##############################################
#                  STORAGE
##############################################
STORAGE_PROVIDER=local
UPLOAD_DIRECTORY=/uploads
NEXT_PUBLIC_UPLOAD_DIRECTORY=/uploads

# Cloudflare R2 storage, optional. Set STORAGE_PROVIDER=cloudflare to use.
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# CLOUDFLARE_ACCESS_KEY=your-access-key
# CLOUDFLARE_SECRET_ACCESS_KEY=your-secret-access-key
# CLOUDFLARE_BUCKETNAME=your-bucket-name
# CLOUDFLARE_BUCKET_URL=https://your-bucket-url.r2.cloudflarestorage.com/
# CLOUDFLARE_REGION=auto

##############################################
#                 DATABASE
##############################################
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_USER=postiz-user
POSTGRES_DB=postiz-db-local

##############################################
