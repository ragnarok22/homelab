# Copy to scripts/alerts.env and adjust locally. scripts/alerts.env is ignored by git.

# ntfy endpoint used by host-side scripts.
NTFY_URL=https://ntfy.example.com
NTFY_TOPIC=homelab-alerts
# NTFY_TOKEN=tk_replace_me
# NTFY_TIMEOUT=10

# Optional Uptime Kuma Push Monitor URLs.
# KUMA_BACKUP_PUSH_URL=https://status.example.com/api/push/backup-token
# KUMA_DISK_PUSH_URL=https://status.example.com/api/push/disk-token
# KUMA_TIMEOUT=10

# Disk monitor defaults.
DISK_CHECK_PATH=/home/Data
DISK_ALERT_THRESHOLD=90
